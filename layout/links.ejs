<%
  var linksCfg = theme.links || {};
  var linksTitle = linksCfg.links_title || '友情链接';
  var linksSubtitle = linksCfg.links_subtitle || '与优秀的开发者们互相学习，共同进步，以下是我精心挑选的技术伙伴们';
  var defaultCover = url_for('/images/featured-default.png');
  var cover = linksCfg.links_cover || defaultCover;
  var grouped = links_grouped();
  var groups = grouped.groups || [];
  var totalLinks = grouped.total || 0;
  var totalGroups = groups.length;
  var basic = theme.basic || {};
  var social = theme.social || {};
  var applyCfg = linksCfg.apply || {};
  var showApply = applyCfg.enable !== false;

  var applyName = applyCfg.site_name || basic.logo_text || config.title || '';
  var applyDesc = applyCfg.site_description || basic.tagline || config.description || social.author_bio || '';
  var applyUrl = applyCfg.site_url || (config.url ? String(config.url).replace(/\/$/, '') + '/' : '/');
  var applyAvatar = applyCfg.site_avatar || social.author_avatar || basic.logo_image || theme.favicon || url_for('/images/logo.png');
  var applyRss = applyCfg.site_rss || social.rss || url_for('/' + ((theme.feed && theme.feed.path) || 'atom.xml'));
  if (typeof absolute_url === 'function') {
    if (applyAvatar && applyAvatar.charAt(0) === '/') applyAvatar = absolute_url(applyAvatar);
    if (applyRss && applyRss.charAt(0) === '/') applyRss = absolute_url(applyRss);
    if (applyUrl && applyUrl.charAt(0) === '/') applyUrl = absolute_url(applyUrl);
  }

  var applySteps = Array.isArray(applyCfg.steps) && applyCfg.steps.length
    ? applyCfg.steps
    : [
        { title: '添加本站友链', desc: '请先复制左侧本站信息，并添加到贵站的友情链接中' },
        { title: '评论留言', desc: '在本页下方评论区留言申请，提供贵站名称、简介、链接与头像' },
        { title: '等待审核', desc: '审核通过后会添加友链，请耐心等待' }
      ];
  var notice = applyCfg.notice || {};
  var disclaimer = applyCfg.disclaimer || {};
  var showNotice = notice.enable !== false && Array.isArray(notice.items) && notice.items.length;
  var showDisclaimer = disclaimer.enable !== false && Array.isArray(disclaimer.items) && disclaimer.items.length;

  var siteFields = [
    { label: '站点名称', value: applyName },
    { label: '站点描述', value: applyDesc },
    { label: '站点链接', value: applyUrl },
    { label: '头像链接', value: applyAvatar },
    { label: 'RSS 地址', value: applyRss }
  ].filter(function (f) { return f.value; });
%>
<div class="layout-grid no-sidebar">
  <div class="content-area">
    <section class="links-hero">
      <% if (cover) { %>
      <div class="links-hero-bg"><img src="<%= cover %>" alt="" loading="lazy" /></div>
      <div class="links-hero-overlay"></div>
      <% } else { %>
      <div class="links-hero-bg--fallback"></div>
      <% } %>
      <div class="links-hero-content">
        <div class="links-hero-left">
          <span class="links-hero-eyebrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
            </svg>
            <span><%= linksTitle %></span>
          </span>
          <h1><%= linksTitle %></h1>
          <p class="links-hero-desc"><%= linksSubtitle %></p>
          <div class="links-hero-stats">
            <div class="links-hero-stat">
              <div class="links-hero-stat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="2" y1="12" x2="22" y2="12" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              </div>
              <div class="links-hero-stat-text">
                <span class="links-hero-stat-num"><%= totalLinks %></span>
                <span class="links-hero-stat-label">友链网站</span>
              </div>
            </div>
            <span class="links-hero-stat-divider"></span>
            <div class="links-hero-stat">
              <div class="links-hero-stat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
              </div>
              <div class="links-hero-stat-text">
                <span class="links-hero-stat-num"><%= totalGroups %></span>
                <span class="links-hero-stat-label">链接分组</span>
              </div>
            </div>
            <span class="links-hero-stat-divider"></span>
            <div class="links-hero-stat">
              <div class="links-hero-stat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 16a6 6 0 0 1 12 0" />
                  <path d="M6 8a6 6 0 0 1 12 0" />
                </svg>
              </div>
              <div class="links-hero-stat-text">
                <span class="links-hero-stat-num">∞</span>
                <span class="links-hero-stat-label">无限可能</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="links-section">
      <div class="links-section-header">
        <h2>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-4.5 17.04-8.2 17.04z" />
            <path d="M2 21c0-3 1.85-5.36 5.08-6" />
          </svg>
          友链列表
        </h2>
      </div>

      <% if (groups.length) { %>
      <div class="links-toolbar">
        <nav class="link-filters" id="linkFilters">
          <button type="button" class="link-filter active" data-group="__all__">
            <span>全部</span>
            <small><%= totalLinks %></small>
          </button>
          <% groups.forEach(function(grp) { %>
          <button type="button" class="link-filter" data-group="<%= grp.name %>">
            <span><%= grp.display_name %></span>
            <small><%= (grp.links || []).length %></small>
          </button>
          <% }); %>
        </nav>
        <div class="links-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input type="text" id="linksSearchInput" placeholder="搜索友链..." autocomplete="off" />
        </div>
      </div>
      <% } %>

      <% if (groups.length) { %>
        <% groups.forEach(function(grp) { %>
        <section class="link-group" data-link-group data-group-name="<%= grp.name %>">
          <% if (totalGroups > 1) { %>
          <header class="link-group-header">
            <h3><%= grp.display_name || '未分组' %></h3>
            <small><%= (grp.links || []).length %> 个站点</small>
          </header>
          <% } %>
          <% if (grp.links && grp.links.length) { %>
          <div class="link-cards">
            <% grp.links.forEach(function(link) {
                 var displayName = link.name || link.display_name || 'Link';
                 var logo = link.logo || '';
                 var desc = link.description || '';
            %>
            <a
              href="<%= link.url %>"
              class="link-card"
              target="_blank"
              rel="noopener"
              data-link-item
              data-name="<%= displayName %>"
              data-desc="<%= desc %>"
              data-url="<%= link.url %>"
            >
              <div class="link-card-head">
                <div class="link-card-logo<%= logo ? '' : ' is-fallback' %>">
                  <% if (logo) { %>
                  <img src="<%= logo %>" alt="<%= displayName %>" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('is-fallback');" />
                  <% } %>
                  <span class="link-card-logo-fallback"><%= displayName.charAt(0) %></span>
                </div>
                <div class="link-card-title-row">
                  <span class="link-card-name"><%= displayName %></span>
                  <span class="link-card-url"><%= link.url %></span>
                </div>
                <svg class="link-card-external" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
              </div>
              <% if (desc) { %><p class="link-card-desc"><%= desc %></p><% } %>
              <div class="link-card-footer">
                <span class="link-tag"><%= grp.display_name %></span>
              </div>
            </a>
            <% }); %>
          </div>
          <% } else { %>
          <div class="empty-state"><p>该分组下暂无链接</p></div>
          <% } %>
        </section>
        <% }); %>
      <% } else { %>
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </svg>
        <p>暂无友情链接</p>
      </div>
      <% } %>

      <div class="links-search-empty" id="linksSearchEmpty" style="display: none">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <p>未找到匹配的友链</p>
        <small>尝试使用其他关键词搜索</small>
      </div>
    </section>

    <% if (showApply) { %>
    <section class="links-apply" aria-label="申请友链">
      <div class="links-apply-grid">
        <article class="links-site-card">
          <header class="links-site-card-head">
            <div class="links-site-avatar<%= applyAvatar ? '' : ' is-fallback' %>">
              <% if (applyAvatar) { %>
              <img src="<%= applyAvatar %>" alt="<%= applyName %>" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('is-fallback');" />
              <% } %>
              <span class="links-site-avatar-fallback"><%= (applyName || '站').charAt(0) %></span>
            </div>
            <div class="links-site-meta">
              <h3 class="links-site-name"><%= applyName || '本站' %></h3>
              <% if (applyDesc) { %><p class="links-site-tagline"><%= applyDesc %></p><% } %>
            </div>
          </header>
          <div class="links-site-fields">
            <% siteFields.forEach(function(field) { %>
            <div class="links-site-field">
              <div class="links-site-field-text">
                <span class="links-site-field-label"><%= field.label %></span>
                <span class="links-site-field-value" title="<%= field.value %>"><%= field.value %></span>
              </div>
              <button
                type="button"
                class="links-copy-btn"
                data-copy="<%= field.value %>"
                aria-label="复制<%= field.label %>"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2" />
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                </svg>
                <span data-copy-label>复制</span>
              </button>
            </div>
            <% }); %>
          </div>
        </article>

        <article class="links-apply-card">
          <header class="links-apply-card-head">
            <span class="links-apply-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <path d="M9 15l2 2 4-4" />
              </svg>
            </span>
            <h3>申请友链</h3>
          </header>
          <ol class="links-apply-steps">
            <% applySteps.forEach(function(step, idx) { %>
            <li class="links-apply-step">
              <span class="links-apply-step-num"><%= idx + 1 %></span>
              <div class="links-apply-step-body">
                <strong><%= step.title || ('步骤 ' + (idx + 1)) %></strong>
                <% if (step.desc) { %><p><%= step.desc %></p><% } %>
              </div>
            </li>
            <% }); %>
          </ol>
        </article>
      </div>

      <% if (showNotice || showDisclaimer) { %>
      <div class="links-accordions">
        <% if (showNotice) { %>
        <details class="links-accordion"<%= notice.open !== false ? ' open' : '' %>>
          <summary>
            <span><%= notice.title || '友链须知' %></span>
            <svg class="links-accordion-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div class="links-accordion-body">
            <ul>
              <% notice.items.forEach(function(item) { %>
              <li><%= item %></li>
              <% }); %>
            </ul>
          </div>
        </details>
        <% } %>
        <% if (showDisclaimer) { %>
        <details class="links-accordion"<%= disclaimer.open ? ' open' : '' %>>
          <summary>
            <span><%= disclaimer.title || '免责声明' %></span>
            <svg class="links-accordion-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div class="links-accordion-body">
            <ul>
              <% disclaimer.items.forEach(function(item) { %>
              <li><%= item %></li>
              <% }); %>
            </ul>
          </div>
        </details>
        <% } %>
      </div>
      <% } %>
    </section>
    <% } %>

    <%- partial('_partial/comment') %>
  </div>
</div>

<script src="<%- url_for('/js/links.js') %>" defer></script>
