<%
  var basic = theme.basic || {};
  var footer = theme.footer || {};
  var social = theme.social || {};
  var showFooterMain = footer.show_footer_main !== false;
  var footerLogo = footer.logo_image || basic.logo_image || url_for('/images/logo.png');
  var footerLogoWidth = footer.logo_image_width || basic.logo_image_width || 40;
  var footerLogoHeight = footer.logo_image_height || basic.logo_image_height || 40;
  var footerName = footer.logo_text || basic.logo_text || config.title;
  var footerTagline = footer.tagline || basic.tagline || config.subtitle || '';
  var footerDesc = footer.footer_description || footerTagline;
  var githubUrl = social.github || '';
  var emailAddr = social.email || '';
  var wechatUrl = social.wechat || '';
  var rssUrl = social.rss || url_for('/atom.xml');
  var juejinUrl = social.juejin || '';
  var csdnUrl = social.csdn || '';
  var zhihuUrl = social.zhihu || '';
  var subscribeAction = social.footer_subscribe_action || '';
  var privacyUrl = footer.privacy_url || '';
  var termsUrl = footer.terms_url || '';
  var linksUrl = footer.links_url || '';
  var aboutUrl = footer.about_url || '';
  var authorJoinDate = social.author_join_date || '';
  var authorLocation = social.author_location || '';
  var busuanziOn = theme.busuanzi && theme.busuanzi.enable;

  var footerStyleParts = [];
  if (footer.bg_image) footerStyleParts.push("--footer-bg-image: url('" + footer.bg_image + "')");
  if (footer.bg_image_opacity != null) footerStyleParts.push('--footer-bg-img-opacity: ' + footer.bg_image_opacity);
  if (footer.bg_image_dark) footerStyleParts.push("--footer-bg-image-dark: url('" + footer.bg_image_dark + "')");
  if (footer.bg_image_opacity_dark != null) footerStyleParts.push('--footer-bg-img-opacity-dark: ' + footer.bg_image_opacity_dark);
  if (footer.social_color) footerStyleParts.push('--footer-social-color: ' + footer.social_color);
  if (footer.social_color_dark) footerStyleParts.push('--footer-social-color-dark: ' + footer.social_color_dark);
  var footerStyle = footerStyleParts.length ? footerStyleParts.join('; ') + ';' : '';

  var postCount = site.posts.length;
  var catCount = site.categories.length;
  var tagCount = site.tags.length;
%>
<footer class="site-footer"<% if (footerStyle) { %> style="<%= footerStyle %>"<% } %>>
  <div class="container">
    <% if (showFooterMain) { %>
    <div class="footer-main">
      <div class="footer-brand">
        <a class="footer-logo" href="<%- url_for('/') %>">
          <img
            class="footer-logo-image"
            src="<%= footerLogo %>"
            width="<%= footerLogoWidth %>"
            height="<%= footerLogoHeight %>"
            style="width:<%= footerLogoWidth %>px;height:<%= footerLogoHeight %>px;"
            alt="<%= footerName || 'Logo' %>"
          />
          <div class="footer-logo-text">
            <span class="footer-logo-name"><%= footerName %></span>
            <span class="footer-logo-tagline"><%= footerTagline %></span>
          </div>
        </a>
        <p class="footer-desc"><%= footerDesc %></p>
        <div class="footer-social">
          <% if (githubUrl) { %>
          <a class="footer-social-link" href="<%= githubUrl %>" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <% } %>
          <% if (wechatUrl) { %>
          <a class="footer-social-link" href="<%= wechatUrl %>" target="_blank" rel="noopener" aria-label="微信公众号">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.775-1.608a6.843 6.843 0 0 0-.071-1.023c0-4.054-3.891-7.343-8.691-7.343z"/></svg>
          </a>
          <% } %>
          <a class="footer-social-link" href="<%= rssUrl %>" target="_blank" rel="noopener" aria-label="RSS">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
          </a>
          <a class="footer-social-link<%= emailAddr ? '' : ' is-disabled' %>" href="<%= emailAddr ? ('mailto:' + emailAddr) : '#' %>" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
          <% if (juejinUrl) { %>
          <a class="footer-social-link" href="<%= juejinUrl %>" target="_blank" rel="noopener" aria-label="掘金">
            <svg viewBox="0 0 1316 1024" fill="currentColor"><path d="M643.181714 247.698286l154.916572-123.172572L643.181714 0.256 643.072 0l-154.660571 124.269714 154.660571 123.245715 0.109714 0.182857z m0 388.461714h0.109715l399.579428-315.245714-108.361143-87.04-291.218285 229.888h-0.146286l-0.109714 0.146285L351.817143 234.093714l-108.251429 87.04 399.433143 315.136 0.146286-0.146285z m-0.146285 215.552l0.146285-0.146286 534.893715-422.034285 108.397714 87.04-243.309714 192L643.145143 1024 10.422857 525.056 0 516.754286l108.251429-86.893715L643.035429 851.748571z"/></svg>
          </a>
          <% } %>
          <% if (csdnUrl) { %>
          <a class="footer-social-link" href="<%= csdnUrl %>" target="_blank" rel="noopener" aria-label="CSDN">
            <svg viewBox="0 0 1024 1024" fill="currentColor"><path d="M512 1024C229.2224 1024 0 794.7776 0 512 0 229.2224 229.2224 0 512 0c282.7776 0 512 229.2224 512 512 0 282.7776-229.2224 512-512 512z m17.066667-413.525333c34.850133 4.352 68.778667 5.12 102.741333 2.0992 23.04-2.048 44.817067-8.362667 64.170667-21.9136 38.212267-26.794667 49.783467-85.1968 24.251733-123.050667-14.626133-21.7088-36.8128-30.344533-60.757333-35.498667-35.054933-7.543467-70.4512-5.751467-105.847467-3.413333-5.666133 0.3584-6.7584 3.072-7.236267 8.209067-3.072 32.682667-6.536533 65.314133-9.813333 97.962666-2.5088 24.814933-4.932267 49.629867-7.509333 75.605334z m53.4016-33.928534c1.962667-20.906667 3.6352-39.338667 5.4272-57.770666 1.553067-15.906133 3.413333-31.778133 4.727466-47.701334 0.3584-4.283733 1.553067-6.656 5.956267-6.382933 15.616 1.041067 31.709867 0.034133 46.728533 3.652267 36.488533 8.823467 48.725333 54.306133 23.3472 83.029333-15.8208 17.902933-36.7616 23.586133-59.255466 25.088-8.465067 0.546133-17.015467 0.085333-26.9312 0.085333zM512 434.295467c-2.184533-0.648533-3.5328-1.1776-4.932267-1.4336-37.717333-6.877867-75.690667-8.328533-113.646933-2.816-20.974933 3.037867-41.0112 9.489067-57.480533 23.330133-22.9888 19.319467-21.640533 46.848 4.4032 62.0032 13.056 7.594667 28.023467 12.509867 42.5984 17.288533 14.08 4.608 28.996267 6.826667 43.144533 11.264 12.5952 3.925333 14.011733 14.318933 3.584 22.306134-3.345067 2.56-7.441067 5.085867-11.537067 5.751466-11.195733 1.826133-22.698667 4.386133-33.826133 3.566934-24.098133-1.774933-48.042667-5.461333-72.5504-8.430934-1.365333 10.615467-2.935467 23.0912-4.5568 35.9424 4.181333 1.365333 7.68 2.730667 11.264 3.618134 33.9456 8.4992 68.386133 9.608533 102.912 5.12 20.087467-2.6112 39.4752-7.901867 56.695467-19.029334 28.603733-18.4832 36.693333-57.1904-4.676267-75.383466-14.506667-6.382933-30.190933-10.410667-45.482667-15.086934-11.4176-3.4816-23.313067-5.614933-34.525866-9.5232-9.7792-3.413333-11.144533-12.202667-3.037867-18.397866 4.6592-3.549867 10.717867-6.997333 16.384-7.3728a480.853333 480.853333 0 0 1 53.384533-0.853334c15.377067 0.699733 30.651733 3.549867 46.4896 5.5296L512 434.295467z m257.143467 2.048L750.933333 614.2976h54.152534c4.778667-45.636267 9.710933-90.7264 14.062933-135.8848 0.6144-6.365867 2.3552-8.840533 8.686933-9.0112 11.434667-0.273067 22.8864-1.979733 34.286934-1.570133 23.722667 0.853333 42.3936 9.728 38.4 43.264-2.901333 24.2688-5.597867 48.571733-8.2432 72.874666-1.092267 10.069333-1.826133 20.189867-2.730667 30.4128h55.330133c3.584-35.259733 7.9872-70.058667 10.496-104.994133 3.413333-47.4624-17.7664-73.3184-64.682666-80.213333-40.96-6.007467-81.339733-0.341333-121.5488 7.133866z m-483.498667 134.6048c-8.738133 1.297067-16.384 2.798933-24.098133 3.4816-25.6512 2.235733-51.319467 3.9424-76.305067-4.266667-13.909333-4.590933-24.6784-12.578133-29.7984-25.9584-7.901867-20.701867 0.887467-47.104 19.831467-60.3136 17.373867-12.117333 37.717333-15.9232 58.453333-15.9232 22.545067-0.017067 45.090133 2.423467 68.232533 3.84L307.2 432.298667c-15.069867-1.723733-29.4912-3.925333-43.997867-4.9152-41.0112-2.798933-80.64 2.6112-117.469866 20.462933-30.020267 14.557867-52.053333 36.010667-58.6752 68.130133-7.850667 38.144 11.537067 69.495467 51.7632 85.845334 19.1488 7.765333 39.287467 12.509867 60.0064 12.5952 24.746667 0.1024 49.493333-1.570133 74.205866-2.952534 3.106133-0.170667 8.311467-2.901333 8.669867-5.034666 1.979733-11.554133 2.730667-23.278933 3.9424-35.464534z"/></svg>
          </a>
          <% } %>
          <% if (zhihuUrl) { %>
          <a class="footer-social-link" href="<%= zhihuUrl %>" target="_blank" rel="noopener" aria-label="知乎">
            <svg viewBox="0 0 1024 1024" fill="currentColor"><path d="M656.90624 724.29056l47.42144-33.72544h52.68992V344.89856h-143.31904v346.7264h35.82976z"/><path d="M849.92 51.2H174.08c-67.8656 0-122.88 55.0144-122.88 122.88v675.84c0 67.8656 55.0144 122.88 122.88 122.88h675.84c67.8656 0 122.88-55.0144 122.88-122.88V174.08c0-67.8656-55.0144-122.88-122.88-122.88zM495.66208 803.34848l-101.1712-157.05088 44.26752-31.616 67.45088 98.00704c-0.00512 0 23.17824 37.99552-10.5472 90.65984z m38.99392-276.10112v25.2928H408.19712C357.61152 876.06784 204.8 807.04512 204.8 807.04512c140.16512-109.86496 142.7968-254.50496 142.7968-254.50496H208.49152c0-57.9584 52.16256-56.91392 52.16256-56.91392h93.79328v-151.7568h-50.5856C284.89728 429.2352 204.8 425.02144 204.8 425.02144s32.67072-50.5856 54.79936-137.00096c22.12864-86.42048 89.5744-76.928 89.5744-76.928-20.0192 35.82976-29.50656 76.928-29.50656 76.928H485.12c40.04864 0 37.9392 25.2928 37.9392 25.2928v29.51168H411.35616v152.8064H503.04c33.72544 0 31.616 31.616 31.616 31.616zM819.2 747.49952h-102.22592l-88.51968 55.84896-8.42752-55.84896h-64.29184V288.01536H819.2v459.48416z"/></svg>
          </a>
          <% } %>
        </div>
      </div>

      <div class="footer-middle">
        <div class="footer-card footer-profile-card">
          <div class="footer-profile-stats">
            <div class="footer-stat-cell">
              <span class="footer-stat-cell-icon footer-stat-icon-visit" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </span>
              <% if (busuanziOn) { %>
              <span class="footer-stat-cell-value" id="busuanzi_value_site_pv">-</span>
              <% } else { %>
              <span class="footer-stat-cell-value">0</span>
              <% } %>
              <span class="footer-stat-cell-label">访问量</span>
            </div>
            <div class="footer-stat-cell">
              <span class="footer-stat-cell-icon footer-stat-icon-like" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
              </span>
              <span class="footer-stat-cell-value">0</span>
              <span class="footer-stat-cell-label">点赞数</span>
            </div>
            <div class="footer-stat-cell">
              <span class="footer-stat-cell-icon footer-stat-icon-comment" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </span>
              <span class="footer-stat-cell-value">0</span>
              <span class="footer-stat-cell-label">评论数</span>
            </div>
            <a class="footer-stat-cell" href="<%- url_for('/archives/') %>">
              <span class="footer-stat-cell-icon footer-stat-icon-post" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
              </span>
              <span class="footer-stat-cell-value"><%= postCount %></span>
              <span class="footer-stat-cell-label">文章数</span>
            </a>
            <a class="footer-stat-cell" href="<%- url_for('/categories/') %>">
              <span class="footer-stat-cell-icon footer-stat-icon-category" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              </span>
              <span class="footer-stat-cell-value"><%= catCount %></span>
              <span class="footer-stat-cell-label">分类数</span>
            </a>
            <a class="footer-stat-cell" href="<%- url_for('/tags/') %>">
              <span class="footer-stat-cell-icon footer-stat-icon-tag" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              </span>
              <span class="footer-stat-cell-value"><%= tagCount %></span>
              <span class="footer-stat-cell-label">标签数</span>
            </a>
            <% if (authorJoinDate) { %>
            <div class="footer-stat-cell">
              <span class="footer-stat-cell-icon footer-stat-icon-join" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </span>
              <span class="footer-stat-cell-value footer-stat-cell-value-text"><%= authorJoinDate %></span>
              <span class="footer-stat-cell-label">建站时间</span>
            </div>
            <% } %>
            <% if (authorLocation) { %>
            <div class="footer-stat-cell">
              <span class="footer-stat-cell-icon footer-stat-icon-location" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span class="footer-stat-cell-value footer-stat-cell-value-text"><%= authorLocation %></span>
              <span class="footer-stat-cell-label">博主地址</span>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="footer-subscribe">
        <h4 class="footer-subscribe-title">订阅更新</h4>
        <p class="footer-subscribe-desc">订阅我们的技术文章，每周精选内容送达你的邮箱</p>
        <form class="footer-subscribe-form" action="<%= subscribeAction || '#' %>" method="post">
          <label class="footer-input-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input type="email" name="email" placeholder="输入你的邮箱" required />
          </label>
          <button type="submit" class="footer-subscribe-btn">订阅</button>
        </form>
        <div class="footer-legal">
          <% var legalItems = []; %>
          <% if (privacyUrl) { legalItems.push({url: privacyUrl, label: '隐私政策', icon: 'lock'}); } %>
          <% if (termsUrl) { legalItems.push({url: termsUrl, label: '使用条款', icon: 'doc'}); } %>
          <% if (linksUrl) { legalItems.push({url: linksUrl, label: '友情链接', icon: 'link'}); } %>
          <% if (aboutUrl) { legalItems.push({url: aboutUrl, label: '关于我们', icon: 'info'}); } %>
          <% legalItems.forEach(function(item, i) { %>
            <% if (i > 0) { %><span>|</span><% } %>
            <a class="footer-legal-link" href="<%= item.url %>" target="_blank" rel="noopener">
              <% if (item.icon === 'lock') { %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <% } else if (item.icon === 'doc') { %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
              <% } else if (item.icon === 'link') { %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <% } else { %>
