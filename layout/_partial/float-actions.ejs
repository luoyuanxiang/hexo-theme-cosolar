<%
  var backTop = theme.back_to_top || {};
  var backTopEnable = backTop.enable !== false;
  var isPostPage = typeof is_post === 'function' ? is_post() : false;
  var upvoteOn = isPostPage && theme.upvote && theme.upvote.enable;
  var showPostActions = isPostPage;
  var showFloat = backTopEnable || showPostActions;

  if (showFloat) {
    var floatPos = (backTop.position || 'right').toLowerCase() === 'left' ? 'left' : 'right';
    var showHeight = backTop.show_height != null ? backTop.show_height : 400;
%>
<div
  class="float-actions float-actions--<%= floatPos %><%= showPostActions ? ' float-actions--post' : '' %>"
  id="floatActions"
  data-show-height="<%= showHeight %>"
  data-backtop-enable="<%= backTopEnable ? 'true' : 'false' %>"
>
  <% if (showPostActions) { %>
  <div class="reading-progress" id="readingProgress" aria-hidden="true"></div>
  <button type="button" class="action-btn action-toc" id="tocBtn" title="目录" aria-label="打开目录">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="8" y1="6" x2="21" y2="6" />
      <line x1="8" y1="12" x2="21" y2="12" />
      <line x1="8" y1="18" x2="21" y2="18" />
      <line x1="3" y1="6" x2="3.01" y2="6" />
      <line x1="3" y1="12" x2="3.01" y2="12" />
      <line x1="3" y1="18" x2="3.01" y2="18" />
    </svg>
    <span class="action-count toc-percent" id="tocPercent">0%</span>
  </button>
  <% if (upvoteOn) { %>
  <button type="button" class="action-btn action-upvote" id="upvoteBtn" data-post="<%= page.slug || page.path %>" title="点赞" aria-label="点赞">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M7 10v12" />
      <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z" />
    </svg>
    <span class="action-count" id="upvoteCount">0</span>
  </button>
  <% } %>
  <button type="button" class="action-btn action-comment" id="commentBtn" title="评论" aria-label="跳到评论">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
    </svg>
    <span class="action-count" id="commentCount">0</span>
  </button>
  <div class="action-share-wrap">
    <button type="button" class="action-btn action-share" id="shareBtn" title="分享" aria-label="分享">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="18" cy="5" r="3" />
        <circle cx="6" cy="12" r="3" />
        <circle cx="18" cy="19" r="3" />
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
      </svg>
    </button>
    <div class="action-share-menu" id="shareMenu">
      <button type="button" class="share-item" data-share="wechat" title="微信分享">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.5 13.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2zM8.69 4C4.44 4 1 6.94 1 10.6c0 2.1 1.14 3.95 2.9 5.15L3 19l3.2-1.7c.79.2 1.63.3 2.49.3.2 0 .4 0 .6-.02-.16-.5-.25-1.02-.25-1.58 0-3.36 3.2-6.1 7.15-6.1.2 0 .4 0 .6.02C16.3 6.32 12.86 4 8.69 4z"/></svg>
        <span>微信</span>
      </button>
      <button type="button" class="share-item" data-share="weibo" title="微博分享">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.31 8.17c-3.43.34-6.04 2.6-6.04 5.07 0 2.64 3.88 4.4 8.17 3.95 4.28-.44 7.42-2.92 7.42-5.56 0-2.64-3.14-4.4-7.42-3.96-.05 0-.09.02-.13.02z"/></svg>
        <span>微博</span>
      </button>
      <button type="button" class="share-item" data-share="copy" title="复制链接">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <span>复制链接</span>
      </button>
    </div>
  </div>
  <% } %>

  <% if (backTopEnable) { %>
  <button
    type="button"
    class="action-btn action-backtop"
    id="backToTop"
    title="回到顶部"
    aria-label="回到顶部"
    hidden
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="12" y1="19" x2="12" y2="5" />
      <polyline points="5 12 12 5 19 12" />
    </svg>
    <span class="action-count backtop-percent" id="backtopPercent">0%</span>
  </button>
  <% } %>
</div>
<% } %>
