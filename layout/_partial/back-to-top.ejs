<%
  var backTop = theme.back_to_top || {};
  var backTopEnable = backTop.enable !== false;
  if (backTopEnable) {
    var backTopPos = (backTop.position || 'right').toLowerCase() === 'left' ? 'left' : 'right';
    var showHeight = backTop.show_height != null ? backTop.show_height : 400;
%>
<button
  type="button"
  class="back-to-top back-to-top--<%= backTopPos %>"
  id="backToTop"
  title="回到顶部"
  aria-label="回到顶部"
  hidden
  data-show-height="<%= showHeight %>"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <line x1="12" y1="19" x2="12" y2="5" />
    <polyline points="5 12 12 5 19 12" />
  </svg>
</button>
<% } %>
