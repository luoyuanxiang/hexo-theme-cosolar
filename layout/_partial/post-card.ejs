<%
  var postCover = post_cover(post);
  var excerpt = post_excerpt(post, 120);
  var authorName = (theme.social && theme.social.author_name) || config.author || config.title;
  var cats = post.categories ? post.categories.toArray() : [];
  var tags = post.tags ? post.tags.toArray() : [];
  var visit = post.views != null ? post.views : (post.visit != null ? post.visit : 0);
  var upvote = post.upvote != null ? post.upvote : (post.likes != null ? post.likes : 0);
  var postPath = '/' + String(post.path || '').replace(/^\//, '');
%>
<article
  class="article-card"
  data-visit="<%= visit %>"
  data-upvote="<%= upvote %>"
  data-sticky="<%= post.sticky ? '1' : '0' %>"
  data-time="<%= date(post.date, 'YYYYMMDDHHmmss') %>"
  data-path="<%= postPath %>"
  data-word="<%= strip_html(post.content || '').length %>"
>
  <a class="article-thumb" href="<%- url_for(post.path) %>">
    <% if (postCover) { %>
    <img src="<%= postCover %>" alt="" loading="lazy" decoding="async" />
    <% } else { %>
    <span class="article-thumb-placeholder">&lt;/&gt;</span>
    <% } %>
  </a>
  <div class="article-body">
    <h3 class="article-card-title">
      <% if (post.sticky) { %>
      <span class="pinned-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px">
          <line x1="12" y1="17" x2="12" y2="22" />
          <path d="M5 17h14l-1.5-3h-11z" />
          <path d="M8 14V5a4 4 0 0 1 8 0v9" />
        </svg>
        置顶
      </span>
      <% } %>
      <a href="<%- url_for(post.path) %>"><%= post.title %></a>
    </h3>
    <p class="article-card-excerpt"><%= excerpt %></p>
    <% if (tags.length) { %>
    <div class="article-card-tags">
      <% tags.forEach(function(tag) { %>
      <a href="<%- url_for(tag.path) %>" class="tag"><%= tag.name %></a>
      <% }); %>
    </div>
    <% } %>
    <div class="article-card-meta">
      <span class="meta-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        <span><%= authorName %></span>
      </span>
      <% if (cats.length) { %>
      <span class="meta-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
        </svg>
        <a href="<%- url_for(cats[0].path) %>" style="color: inherit"><%= cats[0].name %></a>
      </span>
      <% } %>
      <span class="meta-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        <time><%= date(post.date, 'YYYY-MM-DD') %></time>
      </span>
      <span class="meta-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
          <circle cx="12" cy="12" r="3" />
        </svg>
        <span class="card-visit"><%= visit %></span>
      </span>
    </div>
  </div>
</article>
