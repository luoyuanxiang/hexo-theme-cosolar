<%
  var sb = theme.sidebar || {};
  var social = theme.social || {};
  var modules = sb.sidebar_modules || [
    { module: 'author' },
    { module: 'announcement' },
    { module: 'tag_cloud' },
    { module: 'wechat' },
    { module: 'categories' },
    { module: 'recent' },
    { module: 'links' },
    { module: 'feeds' }
  ];
  var catIcons = ['icon-fengfuduoyuan','icon-bokexinwen','icon-jishufuwu','icon-qianduan','icon-houduankaifa','icon-kaiyuan','icon-blog','icon-web','icon-jisuanjikaifa','icon-fuwuqi'];
  var authorName = social.author_name || config.title;
  var authorAvatar = social.author_avatar || url_for('/images/logo.png');
  var authorBio = social.author_bio || '';
  var authorBg = sb.author_bg_image || '';
  var authorBgCol = sb.author_bg_color || '';
  var hasBg = !!authorBg;
  var hasBgCol = !!authorBgCol;
  var githubUrl = social.github || '';
  var emailAddr = social.email || '';
  var juejinUrl = social.juejin || '';
  var csdnUrl = social.csdn || '';
  var zhihuUrl = social.zhihu || '';
  var rssUrl = social.rss || url_for('/atom.xml');
%>
<aside class="sidebar">
  <% modules.forEach(function(m) {
       var mod = (m && m.module) || m;
  %>

  <% if (mod === 'author' && sb.show_author !== false) { %>
  <div
    class="widget widget-author<%= (hasBg || hasBgCol) ? ' has-bg' : '' %>"
    <% if (hasBg) { %>style="background:url(<%= authorBg %>) center/cover no-repeat;"<% } else if (hasBgCol) { %>style="background:<%= authorBgCol %>;"<% } %>
  >
    <div class="author-profile">
      <div class="author-avatar">
        <img src="<%= authorAvatar %>" alt="<%= authorName %>" />
      </div>
      <h3 class="author-name"><%= authorName %></h3>
      <% if (authorBio) { %><p class="author-bio"><%= authorBio %></p><% } %>
      <div class="author-divider"></div>
      <div class="author-stats">
        <a class="author-stat" href="<%- url_for('/archives/') %>">
          <span class="author-stat-num"><%= site.posts.length %></span>
          <span class="author-stat-label">文章</span>
        </a>
        <a class="author-stat" href="<%- url_for('/categories/') %>">
          <span class="author-stat-num"><%= site.categories.length %></span>
          <span class="author-stat-label">分类</span>
        </a>
        <a class="author-stat" href="<%- url_for('/tags/') %>">
          <span class="author-stat-num"><%= site.tags.length %></span>
          <span class="author-stat-label">标签</span>
        </a>
      </div>
      <div class="author-meta">
        <a href="<%= githubUrl || '#' %>" target="_blank" rel="noopener" aria-label="GitHub" class="author-link<%= githubUrl ? '' : ' is-disabled' %>">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="<%= emailAddr ? ('mailto:' + emailAddr) : '#' %>" aria-label="Email" class="author-link<%= emailAddr ? '' : ' is-disabled' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <a href="<%= juejinUrl || '#' %>" target="_blank" rel="noopener" aria-label="掘金" class="author-link<%= juejinUrl ? '' : ' is-disabled' %>">
          <svg viewBox="0 0 1316 1024" fill="currentColor"><path d="M643.181714 247.698286l154.916572-123.172572L643.181714 0.256 643.072 0l-154.660571 124.269714 154.660571 123.245715 0.109714 0.182857z m0 388.461714h0.109715l399.579428-315.245714-108.361143-87.04-291.218285 229.888h-0.146286l-0.109714 0.146285L351.817143 234.093714l-108.251429 87.04 399.433143 315.136 0.146286-0.146285z m-0.146285 215.552l0.146285-0.146286 534.893715-422.034285 108.397714 87.04-243.309714 192L643.145143 1024 10.422857 525.056 0 516.754286l108.251429-86.893715L643.035429 851.748571z"/></svg>
        </a>
        <a href="<%= csdnUrl || '#' %>" target="_blank" rel="noopener" aria-label="CSDN" class="author-link<%= csdnUrl ? '' : ' is-disabled' %>">
          <svg viewBox="0 0 1024 1024" fill="currentColor"><path d="M512 1024C229.2224 1024 0 794.7776 0 512 0 229.2224 229.2224 0 512 0c282.7776 0 512 229.2224 512 512 0 282.7776-229.2224 512-512 512z"/></svg>
        </a>
        <a href="<%= zhihuUrl || '#' %>" target="_blank" rel="noopener" aria-label="知乎" class="author-link<%= zhihuUrl ? '' : ' is-disabled' %>">
          <svg viewBox="0 0 1024 1024" fill="currentColor"><path d="M849.92 51.2H174.08c-67.8656 0-122.88 55.0144-122.88 122.88v675.84c0 67.8656 55.0144 122.88 122.88 122.88h675.84c67.8656 0 122.88-55.0144 122.88-122.88V174.08c0-67.8656-55.0144-122.88-122.88-122.88z"/></svg>
        </a>
        <a href="<%= rssUrl %>" aria-label="RSS" class="author-link">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
        </a>
      </div>
    </div>
  </div>
  <% } %>

  <% if (mod === 'announcement' && sb.show_announcement !== false && sb.announcement_content) { %>
  <div class="widget widget-announcement">
    <div class="widget-title">
      <span class="title-text">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
          <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
        公告
      </span>
    </div>
    <div class="announcement-content"><%- sb.announcement_content %></div>
  </div>
  <% } %>

  <% if (mod === 'tag_cloud' && sb.show_tag_cloud) { %>
  <%
    var tagLimit = sb.tag_cloud_count || 20;
    var cloudTags = site.tags.sort('length').reverse().limit(tagLimit).toArray();
  %>
  <div class="widget widget-tag-cloud">
    <div class="widget-title">
      <span class="title-text">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
          <line x1="7" y1="7" x2="7.01" y2="7" />
        </svg>
        热门标签
      </span>
      <a class="widget-link" href="<%- url_for('/tags/') %>">全部标签 →</a>
    </div>
    <div class="tag-cloud-body">
      <% cloudTags.forEach(function(tag, iter) {
           var weight = tag.length || 1;
           var size = weight >= 30 ? 16 : 11 + weight * 0.16;
      %>
      <a
        href="<%- url_for(tag.path) %>"
        class="tag-cloud-item"
        style="font-size: <%= size %>px; animation-delay: <%= iter * 0.12 %>s;"
      ><%= tag.name %></a>
      <% }); %>
    </div>
  </div>
  <% } %>

  <% if (mod === 'wechat' && sb.show_wechat_qr && sb.wechat_qr_image) { %>
  <div class="widget widget-wechat">
    <div class="widget-title">
      <span class="title-text">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
        公众号
      </span>
    </div>
    <div class="wechat-qr-body">
      <img class="wechat-qr-img" src="<%= sb.wechat_qr_image %>" alt="公众号二维码" />
      <p class="wechat-qr-text"><%= sb.wechat_qr_title || '扫码关注' %></p>
    </div>
  </div>
  <% } %>

  <% if (mod === 'categories' && sb.show_categories !== false) { %>
  <%
    var catLimit = sb.categories_count || 6;
    var catList = site.categories.limit(catLimit).toArray();
  %>
  <div class="widget">
    <div class="widget-title">
      <span class="title-text">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
        </svg>
        文章分类
      </span>
      <a class="widget-link" href="<%- url_for('/categories/') %>">全部分类 →</a>
    </div>
    <% if (catList.length) { %>
    <div class="category-grid">
      <% catList.forEach(function(cat, iter) {
           var catIcon = catIcons[iter % 10];
      %>
      <a href="<%- url_for(cat.path) %>" class="category-item">
        <span class="category-icon"><i class="iconfont <%= catIcon %>"></i></span>
        <span class="category-info">
          <span class="category-name"><%= cat.name %></span>
          <span class="category-count"><%= cat.length %> 篇</span>
        </span>
      </a>
      <% }); %>
    </div>
    <% } %>
  </div>
  <% } %>

  <% if (mod === 'recent' && sb.show_recent !== false) { %>
  <%
    var recentCount = sb.recent_count || 4;
    var recentPosts = site.posts.sort('-date').limit(recentCount).toArray();
  %>
  <div class="widget">
    <div class="widget-title">
      <span class="title-text">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        近期更新
      </span>
      <a class="widget-link" href="<%- url_for('/archives/') %>">查看全部 →</a>
    </div>
    <div class="recent-list">
      <% recentPosts.forEach(function(post) { %>
      <div class="recent-item">
        <span class="recent-badge">NEW</span>
        <div class="recent-info">
          <div class="recent-title">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
          </div>
          <div class="recent-date"><%= date(post.date, 'YYYY-MM-DD') %></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <% if (mod === 'links' && sb.show_sidebar_links !== false) { %>
  <% var randomLinks = sidebar_links(sb.sidebar_links_count || 5); %>
  <div class="widget widget-sidebar-links">
    <div class="widget-title">
      <span class="title-text">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </svg>
        友情链接
      </span>
      <a class="widget-link" href="<%- url_for('/links/') %>">全部友链 →</a>
    </div>
    <% if (randomLinks.length) { %>
    <div class="sidebar-links-list">
      <% randomLinks.forEach(function(link) {
           var displayName = link.name || link.display_name || 'Link';
           var logo = link.logo || '';
           var desc = link.description || '';
      %>
      <a href="<%= link.url %>" class="sidebar-link-item" target="_blank" rel="noopener">
        <span class="sidebar-link-logo<%= logo ? '' : ' is-fallback' %>">
          <% if (logo) { %>
          <img src="<%= logo %>" alt="<%= displayName %>" loading="lazy" onerror="this.style.display='none';this.parentElement.classList.add('is-fallback');" />
          <% } %>
          <span class="sidebar-link-logo-fallback"><%= displayName.charAt(0) %></span>
        </span>
        <span class="sidebar-link-info">
          <span class="sidebar-link-name"><%= displayName %></span>
          <% if (desc) { %><span class="sidebar-link-desc"><%= desc %></span><% } %>
        </span>
      </a>
      <% }); %>
    </div>
    <% } %>
  </div>
  <% } %>

  <% if (mod === 'feeds' && sb.show_sidebar_feeds !== false) { %>
  <div class="widget widget-sidebar-feeds">
    <div class="widget-title">
      <span class="title-text">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 11a9 9 0 0 1 9 9" />
          <path d="M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1" />
        </svg>
        订阅资讯
      </span>
    </div>
    <div class="empty-state" style="padding: 16px 0;">
      <p style="font-size: 13px; color: var(--color-text-muted); text-align: center; margin: 0;">暂无订阅资讯</p>
    </div>
  </div>
  <% } %>

  <% }); %>
</aside>
