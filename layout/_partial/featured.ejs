<%
  var featuredCfg = theme.featured || {};
  if (featuredCfg.show_featured === false) { /* skip */ } else {
  var slides = featured_posts();
  var slideCount = slides.length;
  var defaultCover = url_for('/images/featured-default.png');
  var usePostCover = featuredCfg.featured_cover_fallback !== false;
  var badgeLabel = '精选推荐';
  var configured = featuredCfg.featured_posts || [];
  if (!configured.length) {
    if ((featuredCfg.fallback || 'latest') === 'pinned') badgeLabel = '置顶推荐';
    else if ((featuredCfg.fallback || 'latest') === 'latest') badgeLabel = '最新发布';
  }
  var authorName = (theme.social && theme.social.author_name) || config.author || config.title;
%>
<% if (slideCount > 0) { %>
<div
  class="featured-carousel"
  data-autoplay="<%= featuredCfg.autoplay !== false %>"
  data-interval="<%= featuredCfg.interval || 5000 %>"
  data-max-slides="<%= featuredCfg.featured_max_count || 5 %>"
>
  <div class="carousel-track">
    <% slides.forEach(function(featured, idx) { %>
    <%
      var fCover = '';
      if (usePostCover && featured.cover) {
        fCover = featured.cover;
      } else if (featuredCfg.featured_cover) {
        fCover = featuredCfg.featured_cover;
      } else {
        fCover = defaultCover;
      }
      var fTags = featured.tags ? featured.tags.toArray() : [];
      var fExcerpt = post_excerpt(featured, 100);
    %>
    <div class="featured-card card carousel-slide<%= idx === 0 ? ' active' : '' %>">
      <% if (fCover) { %>
      <div class="featured-bg" style="background-image:url(<%= fCover %>)"></div>
      <% } else { %>
      <div class="featured-bg--fallback"></div>
      <% } %>
      <div class="featured-overlay"></div>
      <div class="featured-content">
        <span class="featured-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
          </svg>
          <span><%= badgeLabel %></span>
        </span>
        <h2 class="featured-title">
          <a href="<%- url_for(featured.path) %>"><%= featured.title %></a>
        </h2>
        <p class="featured-desc"><%= fExcerpt %></p>
        <% if (fTags.length) { %>
        <div class="featured-tags">
          <% fTags.forEach(function(tag) { %>
          <a href="<%- url_for(tag.path) %>" class="tag"><%= tag.name %></a>
          <% }); %>
        </div>
        <% } %>
        <div style="display:flex;align-items:center;gap:16px;margin-top:8px;flex-wrap:wrap">
          <a class="btn btn-primary btn-sm" href="<%- url_for(featured.path) %>">
            阅读全文
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <div class="featured-meta">
            <span class="meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
              <span><%= authorName %></span>
            </span>
            <span class="meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
              <time><%= date(featured.date, 'YYYY-MM-DD') %></time>
            </span>
            <span class="meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <span>0</span>
            </span>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

  <% if (slideCount > 1) { %>
  <button class="carousel-arrow carousel-prev" aria-label="上一篇">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6" />
    </svg>
  </button>
  <button class="carousel-arrow carousel-next" aria-label="下一篇">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6" />
    </svg>
  </button>
  <div class="carousel-dots">
    <% for (var d = 0; d < slideCount; d++) { %>
    <button class="carousel-dot<%= d === 0 ? ' active' : '' %>" data-index="<%= d %>" aria-label="切换到第 <%= d + 1 %> 个"></button>
    <% } %>
  </div>
  <% } %>
</div>
<% } %>
<% } %>
