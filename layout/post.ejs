<%
  var coverUrl = post_cover(page);
  var authorName = (theme.social && theme.social.author_name) || config.author || config.title;
  var cats = page.categories ? page.categories.toArray() : [];
  var tags = page.tags ? page.tags.toArray() : [];
  var upvoteOn = theme.upvote && theme.upvote.enable;
%>
<div class="post-layout">
  <aside class="post-actions" id="postActions">
    <div class="reading-progress" id="readingProgress" aria-hidden="true"></div>
    <button class="action-btn action-toc" id="tocBtn" title="目录" aria-label="打开目录">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="8" y1="6" x2="21" y2="6" />
        <line x1="8" y1="12" x2="21" y2="12" />
        <line x1="8" y1="18" x2="21" y2="18" />
        <line x1="3" y1="6" x2="3.01" y2="6" />
        <line x1="3" y1="12" x2="3.01" y2="12" />
        <line x1="3" y1="18" x2="3.01" y2="18" />
      </svg>
      <span class="action-count toc-percent" id="tocPercent">0%</span>
    </button>
    <% if (upvoteOn) { %>
    <button class="action-btn action-upvote" id="upvoteBtn" data-post="<%= page.slug || page.path %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 10v12" />
        <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z" />
      </svg>
      <span class="action-count" id="upvoteCount">0</span>
    </button>
    <% } %>
    <button class="action-btn action-comment" id="commentBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
      </svg>
      <span class="action-count">0</span>
    </button>
    <button class="action-btn action-share" id="shareBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="18" cy="5" r="3" />
        <circle cx="6" cy="12" r="3" />
        <circle cx="18" cy="19" r="3" />
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
      </svg>
    </button>
    <div class="action-share-menu" id="shareMenu">
      <button class="share-item" data-share="wechat" title="微信分享">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8.5 13.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2zM8.69 4C4.44 4 1 6.94 1 10.6c0 2.1 1.14 3.95 2.9 5.15L3 19l3.2-1.7c.79.2 1.63.3 2.49.3.2 0 .4 0 .6-.02-.16-.5-.25-1.02-.25-1.58 0-3.36 3.2-6.1 7.15-6.1.2 0 .4 0 .6.02C16.3 6.32 12.86 4 8.69 4z"/></svg>
        <span>微信</span>
      </button>
      <button class="share-item" data-share="weibo" title="微博分享">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.31 8.17c-3.43.34-6.04 2.6-6.04 5.07 0 2.64 3.88 4.4 8.17 3.95 4.28-.44 7.42-2.92 7.42-5.56 0-2.64-3.14-4.4-7.42-3.96-.05 0-.09.02-.13.02z"/></svg>
        <span>微博</span>
      </button>
      <button class="share-item" data-share="copy" title="复制链接">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <span>复制链接</span>
      </button>
    </div>
  </aside>

  <div class="content-area">
    <article class="article-detail">
      <% if (coverUrl) { %>
      <div class="article-detail-cover">
        <img src="<%= coverUrl %>" alt="<%= page.title %>" loading="eager" decoding="async" fetchpriority="high" />
      </div>
      <% } %>

      <header class="article-detail-header" data-post-visit-path="<%= '/' + String(page.path || '').replace(/^\//, '') %>">
        <h1 class="article-detail-title"><%= page.title %></h1>
        <div class="article-detail-meta">
          <span class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
            <span><%= authorName %></span>
          </span>
          <span class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <time><%= date(page.date, 'YYYY-MM-DD') %></time>
          </span>
          <% if (!(theme.visit && theme.visit.enable === false) || (theme.busuanzi && theme.busuanzi.enable)) { %>
          <span class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            <span><span id="postVisitCount">0</span> 阅读</span>
            <% if (theme.busuanzi && theme.busuanzi.enable) { %>
            <span id="busuanzi_value_page_pv" hidden aria-hidden="true">0</span>
            <% } %>
          </span>
          <% } %>
          <span class="meta-item" id="postWordCount" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="8" y1="13" x2="16" y2="13" />
              <line x1="8" y1="17" x2="16" y2="17" />
            </svg>
            <span class="word-count-text"></span>
          </span>
          <span class="meta-item" id="postReadTime" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <span class="read-time-text"></span>
          </span>
          <% if (cats.length) { %>
          <span class="meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
            </svg>
            <% cats.forEach(function(cat) { %>
            <a href="<%- url_for(cat.path) %>" style="color: inherit; margin-right: 4px"><%= cat.name %></a>
            <% }); %>
          </span>
          <% } %>
        </div>
      </header>

      <div class="prose"><%- page.content %></div>

      <footer class="article-footer">
        <% if (tags.length) { %>
        <div class="article-tags-row">
          <% tags.forEach(function(tag) { %>
          <a href="<%- url_for(tag.path) %>" class="tag"><%= tag.name %></a>
          <% }); %>
        </div>
        <% } %>

        <div class="post-nav">
          <% if (page.prev) { %>
          <a class="post-nav-item" href="<%- url_for(page.prev.path) %>">
            <span class="post-nav-label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;display:inline;vertical-align:middle">
                <polyline points="15 18 9 12 15 6" />
              </svg>
              上一篇
            </span>
            <span class="post-nav-title"><%= page.prev.title %></span>
          </a>
          <% } else { %>
          <span class="post-nav-item" style="opacity: 0.4">
            <span class="post-nav-label">上一篇</span>
            <span class="post-nav-title">没有了</span>
          </span>
          <% } %>
          <% if (page.next) { %>
          <a class="post-nav-item next" href="<%- url_for(page.next.path) %>">
            <span class="post-nav-label">
              下一篇
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;display:inline;vertical-align:middle">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </span>
            <span class="post-nav-title"><%= page.next.title %></span>
          </a>
          <% } else { %>
          <span class="post-nav-item next" style="opacity: 0.4">
            <span class="post-nav-label">下一篇</span>
            <span class="post-nav-title">没有了</span>
          </span>
          <% } %>
        </div>
      </footer>
    </article>

    <%- partial('_partial/comment') %>
  </div>

  <aside class="toc-sidebar" id="tocSidebar">
    <div class="toc-widget">
      <div class="toc-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px">
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <line x1="3" y1="6" x2="3.01" y2="6" />
          <line x1="3" y1="12" x2="3.01" y2="12" />
          <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
        <span>目录</span>
      </div>
      <nav class="toc-nav" id="tocNav"></nav>
    </div>
  </aside>
</div>

<div class="toc-drawer-mask" id="tocDrawerMask"></div>
<aside class="toc-drawer" id="tocDrawer" aria-hidden="true">
  <div class="toc-drawer-header">
    <span class="toc-drawer-title">目录</span>
    <button class="toc-drawer-close" id="tocDrawerClose" aria-label="关闭目录">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>
  <nav class="toc-drawer-nav" id="tocDrawerNav"></nav>
</aside>

<script src="<%- url_for('/js/post.js') %>" defer></script>
