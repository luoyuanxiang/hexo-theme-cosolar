<%
  var isIndex = page.type === 'tags-index';
  var tagCfg = theme.tag || {};
  var defaultCover = url_for('/images/featured-default.png');
  var showSidebar = !(theme.sidebar && theme.sidebar.show_sidebar === false);
%>

<% if (isIndex) { %>
<%
  var cover = tagCfg.tags_cover || defaultCover;
  var tags = page.tags || site.tags;
  var tagArr = tags.toArray ? tags.toArray() : (tags || []);
%>
<div class="layout-grid no-sidebar">
  <div class="content-area">
    <section class="page-hero">
      <% if (cover) { %>
      <div class="page-hero-bg"><img src="<%= cover %>" alt="" loading="lazy" /></div>
      <div class="page-hero-overlay"></div>
      <% } else { %>
      <div class="page-hero-bg--fallback"></div>
      <% } %>
      <div class="page-hero-inner">
        <span class="page-hero-eyebrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
            <line x1="7" y1="7" x2="7.01" y2="7" />
          </svg>
          <span>标签</span>
        </span>
        <h1>文章标签</h1>
        <p class="page-hero-desc">共 <span><%= tagArr.length %></span> 个标签</p>
      </div>
    </section>

    <% if (tagArr.length) { %>
    <div class="tag-cards">
      <% tagArr.forEach(function(tag) { %>
      <a href="<%- url_for(tag.path) %>" class="tag-card">
        <div class="tag-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
            <line x1="7" y1="7" x2="7.01" y2="7" />
          </svg>
        </div>
        <div class="tag-card-text">
          <div class="tag-card-name"><%= tag.name %></div>
          <div class="tag-card-count"><%= tag.length %> 篇文章</div>
        </div>
        <svg class="tag-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
      </svg>
      <p>暂无标签</p>
    </div>
    <% } %>
  </div>
</div>

<% } else { %>
<%
  var configCover = tagCfg.tag_cover || '';
  var cover = configCover || defaultCover;
  var posts = page.posts;
  var tagName = page.tag || page.title || '';
  var tagTotal = posts ? posts.length : 0;
  site.tags.forEach(function(t) {
    if (t.name === page.tag) tagTotal = t.length;
  });
%>
<div class="layout-grid<%= showSidebar ? '' : ' no-sidebar' %>">
  <div class="content-area">
    <section class="topic-hero">
      <% if (cover) { %>
      <div class="topic-hero-bg"><img src="<%= cover %>" alt="" loading="lazy" /></div>
      <div class="topic-hero-overlay"></div>
      <% } else { %>
      <div class="topic-hero-bg--fallback"></div>
      <% } %>
      <div class="topic-hero-inner">
        <span class="topic-eyebrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
            <line x1="7" y1="7" x2="7.01" y2="7" />
          </svg>
          <span>标签</span>
        </span>
        <h1 class="topic-title"><%= tagName %></h1>
        <p class="topic-desc">探索此标签下的所有文章</p>
        <div class="topic-stats">
          <span class="topic-stat">
            <span class="topic-stat-num"><%= posts ? posts.length : 0 %></span>
            <span class="topic-stat-label">篇文章</span>
          </span>
          <span class="topic-stat-divider"></span>
          <span class="topic-stat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="topic-stat-icon">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
              <line x1="7" y1="7" x2="7.01" y2="7" />
            </svg>
            <span class="topic-stat-label">标签归档</span>
          </span>
          <span class="topic-stat-divider"></span>
          <span class="topic-stat">
            <a href="<%- url_for('/tags/') %>" class="topic-back-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px">
                <polyline points="15 18 9 12 15 6" />
              </svg>
              <span>全部标签</span>
            </a>
          </span>
        </div>
      </div>
    </section>

    <div class="section-header">
      <h2 class="section-title">文章列表</h2>
    </div>

    <% if (posts && posts.length) { %>
      <% posts.each(function(post) { %>
        <%- partial('_partial/post-card', { post: post }) %>
      <% }); %>
    <% } else { %>
    <div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <polyline points="14 2 14 8 20 8" />
      </svg>
      <p>该标签下暂无文章</p>
    </div>
    <% } %>

    <%- partial('_partial/pagination') %>
  </div>

  <% if (showSidebar) { %>
    <%- partial('_partial/sidebar') %>
  <% } %>
</div>
<% } %>
