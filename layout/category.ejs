<%
  var isIndex = page.type === 'categories-index';
  var catCfg = theme.category || {};
  var defaultCover = url_for('/images/featured-default.png');
  var showSidebar = !(theme.sidebar && theme.sidebar.show_sidebar === false);
%>

<% if (isIndex) { %>
<%
  var cover = catCfg.categories_cover || defaultCover;
  var catArr = list_categories_ui({ mode: catCfg.list_mode || 'top' });
%>
<div class="layout-grid no-sidebar">
  <div class="content-area">
    <section class="page-hero">
      <% if (cover) { %>
      <div class="page-hero-bg"><img src="<%= cover %>" alt="" loading="lazy" /></div>
      <div class="page-hero-overlay"></div>
      <% } else { %>
      <div class="page-hero-bg--fallback"></div>
      <% } %>
      <div class="page-hero-inner">
        <span class="page-hero-eyebrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
          </svg>
          <span>分类</span>
        </span>
        <h1>文章分类</h1>
        <p class="page-hero-desc">共 <span><%= catArr.length %></span> 个分类</p>
      </div>
    </section>

    <% if (catArr.length) { %>
    <div class="category-cards">
      <% catArr.forEach(function(cat) { %>
      <a href="<%- url_for(cat.path) %>" class="category-card">
        <div class="cat-body">
          <div class="cat-info">
            <div class="cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
              </svg>
            </div>
            <div class="cat-text">
              <div class="cat-name"><%= cat.label || cat.name %></div>
              <div class="cat-count"><%= cat.length %> 篇文章</div>
            </div>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
      </svg>
      <p>暂无分类</p>
    </div>
    <% } %>
  </div>
</div>

<% } else { %>
<%
  var configCover = catCfg.category_cover || '';
  var cover = configCover || defaultCover;
  var posts = page.posts;
  var total = page.posts ? page.posts.length : 0;
  if (page.total) total = page.total; // may not exist; use category length
  var catName = page.category || page.title || '';
  // Prefer site category length if available
  var catTotal = posts ? posts.length : 0;
  site.categories.forEach(function(c) {
    if (c.name === page.category) catTotal = c.length;
  });
%>
<div class="layout-grid<%= showSidebar ? '' : ' no-sidebar' %>">
  <div class="content-area">
    <section class="topic-hero">
      <% if (cover) { %>
      <div class="topic-hero-bg"><img src="<%= cover %>" alt="" loading="lazy" /></div>
      <div class="topic-hero-overlay"></div>
      <% } %>
      <div class="topic-hero-inner">
        <span class="topic-eyebrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
          </svg>
          <span>专题</span>
        </span>
        <h1 class="topic-title"><%= catName %></h1>
        <p class="topic-desc">记录此分类下的每一次思考与沉淀</p>
        <div class="topic-stats">
          <span class="topic-stat">
            <span class="topic-stat-num"><%= posts ? posts.length : 0 %></span>
            <span class="topic-stat-label">篇文章</span>
          </span>
          <span class="topic-stat-divider"></span>
          <span class="topic-stat">
            <span class="topic-stat-num"><%= catTotal %></span>
            <span class="topic-stat-label">累计收录</span>
          </span>
          <span class="topic-stat-divider"></span>
          <span class="topic-stat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="topic-stat-icon">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
            </svg>
            <span class="topic-stat-label">专题归档</span>
          </span>
        </div>
      </div>
    </section>

    <div class="section-header">
      <h2 class="section-title">文章列表</h2>
    </div>

    <% if (posts && posts.length) { %>
      <% posts.each(function(post) { %>
        <%- partial('_partial/post-card', { post: post }) %>
      <% }); %>
    <% } else { %>
    <div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <polyline points="14 2 14 8 20 8" />
      </svg>
      <p>该分类下暂无文章</p>
    </div>
    <% } %>

    <%- partial('_partial/pagination') %>
  </div>

  <% if (showSidebar) { %>
    <%- partial('_partial/sidebar') %>
  <% } %>
</div>
<% } %>
